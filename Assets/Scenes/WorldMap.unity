  scenarios:
  - title: "\u041F\u043E\u0442\u0435\u0440\u044F\u043D\u043D\u044B\u0439 \u0442\u043E\u0440\u0433\u043E\u0432\u0435\u0446"
    description: "\u0421\u0442\u0430\u0440\u044B\u0439 \u0442\u043E\u0440\u0433\u043E\u0432\u0435\u0446
      \u043F\u0440\u043E\u0441\u0438\u0442 \u043F\u043E\u043C\u043E\u0449\u0438 \u0438
      \u043E\u0431\u0435\u0449\u0430\u0435\u0442 \u043E\u0442\u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u0438\u0442\u044C."
    optionA: "\u041F\u043E\u043C\u043E\u0447\u044C"
    optionB: "\u041F\u0440\u043E\u0439\u0442\u0438 \u043C\u0438\u043C\u043E"
  - title: "\u0417\u0430\u0433\u0430\u0434\u043E\u0447\u043D\u044B\u0439 \u0441\u0443\u043D\u0434\u0443\u043A"
    description: "\u041F\u0435\u0440\u0435\u0434 \u0432\u0430\u043C\u0438 \u0441\u0443\u043D\u0434\u0443\u043A
      \u0441 \u043D\u0435\u043F\u043E\u043D\u044F\u0442\u043D\u043E\u0439 \u043F\u0435\u0447\u0430\u0442\u044C\u044E."
    optionA: "\u041E\u0442\u043A\u0440\u044B\u0442\u044C"
    optionB: "\u041E\u0441\u0442\u0430\u0432\u0438\u0442\u044C"
  - title: "\u0420\u0430\u043D\u0435\u043D\u044B\u0439 \u0441\u043E\u044E\u0437\u043D\u0438\u043A"
    description: "\u0412\u044B \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u043B\u0438
      \u0441\u043E\u044E\u0437\u043D\u0438\u043A\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
      \u043F\u0440\u043E\u0441\u0438\u0442 \u043F\u0440\u0438\u043F\u0430\u0441\u044B."
    optionA: "\u041F\u043E\u0434\u0434\u0435\u0440\u0436\u0430\u0442\u044C"
    optionB: "\u0418\u0433\u043D\u043E\u0440\u0438\u0440\u043E\u0432\u0430\u0442\u044C"
